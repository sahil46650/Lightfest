generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  password      String?
  phone         String?
  role          UserRole       @default(USER)
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  bookings      Booking[]
  bookingGuests BookingGuest[]
  reviews       Review[]
  sessions      Session[]

  @@index([email])
  @@index([role])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String
  imageUrl    String?
  location    String
  address     String?
  latitude    Float?
  longitude   Float?
  date        DateTime
  endDate     DateTime?
  timezone    String       @default("UTC")
  capacity    Int
  status      EventStatus  @default(PUBLISHED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bookings    Booking[]
  reviews     Review[]
  ticketTypes TicketType[]

  @@index([slug])
  @@index([status])
  @@index([date])
}

model TicketType {
  id                String          @id @default(cuid())
  eventId           String
  name              String
  description       String?
  price             Decimal         @db.Decimal(10, 2)
  quantityTotal     Int
  quantityAvailable Int
  quantitySold      Int             @default(0)
  sortOrder         Int             @default(0)
  availableFrom     DateTime?
  availableTo       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  inventoryLocks    InventoryLock[]
  tickets           Ticket[]
  event             Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Ticket {
  id            String     @id @default(cuid())
  bookingId     String
  ticketTypeId  String
  qrCode        String?    @unique
  scannedAt     DateTime?
  addOnsJson    String?
  price         Decimal    @db.Decimal(10, 2)
  attendeeEmail String?
  attendeeName  String?
  createdAt     DateTime   @default(now())
  booking       Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType    TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([bookingId])
  @@index([ticketTypeId])
  @@index([qrCode])
}

model Booking {
  id                 String         @id @default(cuid())
  confirmationNumber String         @unique @default(cuid())
  eventId            String
  userId             String?
  status             BookingStatus  @default(CONFIRMED)
  email              String
  firstName          String
  lastName           String
  phone              String
  subtotal           Decimal        @db.Decimal(10, 2)
  discount           Decimal        @default(0) @db.Decimal(10, 2)
  serviceFee         Decimal        @db.Decimal(10, 2)
  total              Decimal        @db.Decimal(10, 2)
  promoCodeId        String?
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  confirmedAt        DateTime?
  metadata           String?
  event              Event          @relation(fields: [eventId], references: [id])
  promoCode          PromoCode?     @relation(fields: [promoCodeId], references: [id])
  user               User?          @relation(fields: [userId], references: [id])
  guests             BookingGuest[]
  emailLogs          EmailLog[]
  tickets            Ticket[]

  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([confirmationNumber])
  @@index([email])
}

model BookingGuest {
  id        String   @id @default(cuid())
  bookingId String
  userId    String?
  name      String
  email     String
  order     Int
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([bookingId])
  @@index([userId])
}

model DraftBooking {
  id             String          @id @default(cuid())
  eventId        String
  sessionId      String
  currentStep    CheckoutStep    @default(TICKET_SELECTION)
  cart           String
  personalInfo   String?
  attendees      String?
  promoCodeId    String?
  expiresAt      DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  promoCode      PromoCode?      @relation(fields: [promoCodeId], references: [id])
  inventoryLocks InventoryLock[]

  @@index([sessionId])
  @@index([eventId])
  @@index([expiresAt])
}

model InventoryLock {
  id             String       @id @default(cuid())
  draftBookingId String
  ticketTypeId   String
  quantity       Int
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  draftBooking   DraftBooking @relation(fields: [draftBookingId], references: [id], onDelete: Cascade)
  ticketType     TicketType   @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@index([draftBookingId])
  @@index([ticketTypeId])
  @@index([expiresAt])
}

model PromoCode {
  id                String         @id @default(cuid())
  code              String         @unique
  description       String?
  discountType      DiscountType   @default(PERCENTAGE)
  discountValue     Decimal        @db.Decimal(10, 2)
  maxUses           Int?
  usedCount         Int            @default(0)
  expiresAt         DateTime?
  minPurchaseAmount Decimal?       @db.Decimal(10, 2)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  bookings          Booking[]
  draftBookings     DraftBooking[]

  @@index([code])
  @@index([expiresAt])
}

model Review {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  rating    Int
  title     String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EmailLog {
  id             String        @id @default(cuid())
  bookingId      String?
  recipientEmail String
  templateType   EmailTemplate
  status         EmailStatus   @default(PENDING)
  subject        String?
  content        String?
  error          String?
  sentAt         DateTime?
  attempts       Int           @default(0)
  nextRetryAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  booking        Booking?      @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventName String
  eventData String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([eventName])
  @@index([createdAt])
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  SOLD_OUT
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum CheckoutStep {
  TICKET_SELECTION
  PERSONAL_INFO
  ATTENDEE_INFO
  PAYMENT
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum EmailTemplate {
  BOOKING_CONFIRMATION
  EVENT_REMINDER
  ABANDONED_CART
  PASSWORD_RESET
  WELCOME
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}
