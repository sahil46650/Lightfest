  "/api/v1/orders":
    get:
      tags[1]: Orders
      summary: Get a list of orders
      description: Returns a list of orders
      produces[1]: application/json
      parameters[21]:
        - name: search
          in: query
          description: "Search term to use for filtering, must be at least 3 characters, matches against order ID, barcode, and shipping or billing first and last name, and attendee name."
          type: string
        - name: orderHash
          in: query
          description: Find the order for this hash
          type: string
        - name: purchaserFirstName
          in: query
          description: Search for an attendees first name (add percent on either side for partial name)
          type: string
        - name: purchaserLastName
          in: query
          description: "Search for an attendees last name (add percent on either side for partial name - ex: 'Smi%') "
          type: string
        - name: fromDate
          in: query
          description: Only orders purchased after than this date
          type: string
        - name: toDate
          in: query
          description: Only orders purchased before than this date
          type: string
        - name: updatedFrom
          in: query
          description: Only orders updated after this date
          type: string
        - name: updatedTo
          in: query
          description: Only orders updated before this date
          type: string
        - name: eventId
          in: query
          description: Only orders with a ticket for this event
          type: string
        - name: typeId
          in: query
          description: Only orders with a ticket for this ticket type
          type: string
        - name: customerId
          in: query
          description: Only orders made by this user (synonymous with userId)
          type: string
        - name: userId
          in: query
          description: Only orders made by this user (synonymous with customerId)
          type: string
        - name: externalId
          in: query
          description: Only orders made by this external user (SSO)
          type: string
        - name: teamTicket
          in: query
          description: Only orders with tickets that do have a team assigned
          type: boolean
        - name: individualTicket
          in: query
          description: Only orders with tickets that do not have a team assigned
          type: boolean
        - name: change
          in: query
          description: "Include new order id\\old order id if applicable."
          type: boolean
        - name: checkedIn
          in: query
          description: Only orders with (or without) a checked in ticket
          type: boolean
        - name: limit
          in: query
          description: Limit returned results
          type: integer
        - name: offset
          in: query
          description: Offset returned results
          type: integer
        - name: sortBy
          in: query
          description: Sorting direction
          type: array
          items:
            type: string
            enum[2]: purchaseDate,lastUpdated
        - name: sortDirection
          in: query
          description: Sort by
          type: array
          items:
            type: string
            enum[2]: asc,desc
      responses:
        "200":
          description: success
          schema:
            "$ref": #/definitions/ListApiResponseObject
    post:
      tags[1]: Orders
      summary: Attempt to run the checkout process
      description: Attempt to run the checkout process
      produces[1]: application/json
      parameters[1]:
        - name: orderData
          in: body
