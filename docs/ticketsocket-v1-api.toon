  "/api/v1/events":
    get:
      tags[1]: Event
      summary: List all events for site
      description: "\r\nGets a list of events that match the filtering parameters.\r\n\r\nSearching:\r\n\r\nIn order to perform searches, users can provide a string using the\r\n**search** parameter. The search parameter will be matched with a like search on the title and URL of the event.\r\nAs an example, /api/v1/events/?search=Rockstar\r\n\r\nwill produce an SQL statement equivalent to:\r\n\r\n(\\`title\\` LIKE '%Rockstar%' || `url` LIKE '%Rockstar%')\r\n\r\nA category ID can be given using the **category** parameter, as an example /api/v1/events/?category=1\r\n\r\nWill filter the list to events that are linked to category 1.\r\n\t\t"
      produces[1]: application/json
      parameters[18]{name,in,description,type}:
        search,query,search terms to use for filtering,string
        externalId,query,External event ID to match against,string
        category,query,category to use for filtering,integer
        tags,query,include events tagged with these comma separated tags,string
        includeEnded,query,include events that have ended in the results,boolean
        includeOffSale,query,include events that are not on sale in the results,boolean
        includeTicketTypes,query,include ticket type data for each event,boolean
        includeWaveTimes,query,include wave time data for each event,boolean
        startsBefore,query,Limit to events starting before this date/time.,string
        startsAfter,query,Limit to events starting after this date/time.,string
        endsBefore,query,Limit to events ending before this date/time.,string
        endsAfter,query,Limit to events ending after this date/time.,string
        promoCodeRequired,query,Limit to events that require a promo code.,boolean
        company,query,Filter based on company/organization.,string
        orderBy,query,"start, end, cutOff, id, title",string
        orderDirection,query,asc or desc,string
        limit,query,limit for items per page,integer
        offset,query,offset for pagination,integer
      responses:
        "200":
          description: success
          schema:
            "$ref": #/definitions/ListApiResponseObject
    post:
      tags[1]: Event
      summary: Create a new event
      description: Create a new event
      produces[1]: application/json
      parameters[1]:
        - name: requestData
          in: body
          schema:
            "$ref": #/definitions/EventCreateParamsObject
      responses:
        "200":
          description: success
          schema:
            "$ref": #/definitions/SingleApiResponseObject
  "/api/v1/public-events":
    get:
      tags[1]: Event
      summary: List all events for site
      description: "\r\nGets a list of public events that match the filtering parameters.\r\n\r\nSearching:\r\n\r\nIn order to perform searches, users can provide a string using the\r\n**search** parameter. The search parameter will be matched with a like search on the title and URL of the event.\r\nAs an example, /api/v1/public-events/?search=Rockstar\r\n\r\nwill produce an SQL statement equivalent to:\r\n\r\n(\\`title\\` LIKE '%Rockstar%' || `url` LIKE '%Rockstar%')\r\n\r\nA category ID can be given using the **category** parameter, as an example /api/v1/public-events/?category=1\r\n\r\nWill filter the list to events that are linked to category 1.\r\n\t\t"
      produces[1]: application/json
      parameters[14]{name,in,description,type}:
        search,query,search terms to use for filtering,string
        externalId,query,External event ID to match against,string
        category,query,category to use for filtering,integer
        tags,query,include events tagged with these comma separated tags,string
        includeOffSale,query,include events that are not on sale in the results,boolean
        startsBefore,query,Limit to events starting before this date/time.,string
        startsAfter,query,Limit to events starting after this date/time.,string
        endsBefore,query,Limit to events ending before this date/time.,string
        endsAfter,query,Limit to events ending after this date/time.,string
        company,query,Filter based on company/organization.,string
        orderBy,query,"start, end, cutOff, id, title",string
        orderDirection,query,asc or desc,string
        limit,query,limit for items per page,integer
        offset,query,offset for pagination,integer
      responses:
        "200":
          description: success
          schema:
            "$ref": #/definitions/ListApiResponseObject
