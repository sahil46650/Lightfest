        lastUpdate,query,Limit to tickets updated after this timestamp or time string,string
        processState,query,Limit to tickets not scanned (0) or scanned/checkedIn (2) or shipped (4),string
        scannedBy,query,Limit to tickets to those scanned by this Administrator Id,string
        limit,query,Limit the results,integer
        offset,query,Offset the results,integer
