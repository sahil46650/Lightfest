  "/api/v1/tokens":
    post:
      tags[1]: Tokens
      summary: Generates tokens
      description: Generates a token that must be used for all write operations
      produces[1]: application/json
      parameters[1]:
        - name: publicKey
          in: body
          schema:
            "$ref": #/definitions/TokenCreateParamObject
      responses:
        "200":
          description: success
  "/api/v1/tokens/without-key":
    post:
      tags[1]: Tokens
      summary: Generates tokens
      description: Generates a token that can be used for login operations
      produces[1]: application/json
      parameters[1]:
        - name: publicKey
          in: body
          schema:
            "$ref": #/definitions/TokenCreateParamObjectWithoutKey
      responses:
        "200":
          description: success
  "/api/v1/waivers":
    get:
      tags[1]: Waivers
      summary: Returns a list of waivers
      description: Returns a list of waivers.
      produces[1]: application/json
      parameters[2]{name,in,description,type}:
        limit,query,Limit returned results,integer
        offset,query,Offset returned results,integer
      responses:
        "200":
          description: success
          schema:
            "$ref": #/definitions/ListApiResponseObject
