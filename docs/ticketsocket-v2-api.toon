openapi: 3.0.0
info:
  title: " API Documentation"
  version: 2.0.0
paths:
  "/api/v2/administrator/login-report":
    get:
      tags[1]: Administrators
      operationId: bcee44eaa0c8deccaa300a84c0d9ce78
      parameters[3]:
        - name: search
          in: query
          description: Limit to results matching this search string
          required: false
          schema:
            type: string
        - name: _limit
          in: query
          description: Limit Results to this number
          required: false
          schema:
            type: integer
            format: int64
        - name: _offset
          in: query
          description: Offset results by this number
          required: false
          schema:
            type: integer
            format: int64
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
  "/api/v2/administrator/my-access":
    get:
      tags[1]: Administrators
      summary: Get the permission for the current admin user.
      operationId: 6077e3ec4d5cc2bbd94bc80366b90fcd
      responses:
        "200":
          description: An object contains the permissions.
        "400":
          "$ref": #/components/responses/ErrorResponse
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
  "/api/v2/administrator/login":
    post:
      tags[1]: Administrators
      summary: Login a user into the v2 api.
      operationId: d7a073e5da891ae62045ce86453c2699
      parameters[1]:
        - name: _include
          in: query
          description: "Adds additional details to the results. Supports the following values:\n *  user - Include additional information about the user login in.\n *  perms - Include permssions for the user login in"
          required: false
          schema:
            type: string
      requestBody:
        description: The user logging in.
        content:
          "application/json":
            schema:
              required[2]: login,password
              properties:
                login:
                  description: The login for the user.
                  type: string
                password:
                  description: The password for the user.
                  type: string
              type: object
      responses:
        "200":
          description: Information for the user who's signin in.
          content:
            "application/json":
              schema:
                properties:
                  token:
                    description: Should be include a the Bearer token in an future call to the api.
                    type: string
                  admin:
                    description: Additional information about the user. Only appears if user with included as one of the _include options.
                    properties:
                      email:
                        description: The email address of the user.
                        type: string
                    type: object
                  perms:
                    description: The permissions for the user. Only perms if user with included as one of the _include options.
                    type: object
                type: object
        "400":
          "$ref": #/components/responses/ErrorResponse
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
  "/api/v2/administrator/password":
    put:
      tags[1]: Administrators
      summary: Updates the current administrator's password.
      operationId: ac943fac8cb9cdbfead93bd849fe66a3
      requestBody:
        description: The password.
        content:
          "application/json":
            schema:
              required[2]: old,new
              properties:
                old:
                  description: The administrator's current password.
                  type: string
                new:
                  description: The administrator's new password.
                  type: string
              type: object
      responses:
        "204":
          description: The password was updated.
        "400":
          "$ref": #/components/responses/ErrorResponse
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
  "/api/v2/answer/{id}":
    get:
      tags[1]: Answers
      summary: Find Answer by Id
      description: Returns a single Answer
      operationId: Answer-findOne
      parameters[1]:
        - name: id
          in: path
          description: id
          required: true
          schema:
            type: integer
            format: int64
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
        "400":
          description: Invalid Webhook
    delete:
      tags[1]: Answers
      summary: Delete one Answer by Id
      description: Deletes the identified Answer
      operationId: Answer-delete
      parameters[1]:
        - name: id
          in: path
          description: id
          required: true
          schema:
            type: integer
            format: int64
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
        "400":
          description: Invalid Webhook
    patch:
      tags[1]: Answers
      summary: Find Answer by Id
      description: Updates an existing Answer from the PATCH data
      operationId: Answer-update
      parameters[1]:
        - name: id
          in: path
          description: id
          required: true
          schema:
            type: integer
            format: int64
      requestBody:
        description: Input Data for Answer
        content:
          "application/json":
            schema:
              allOf[1]{"$ref"}:
                #/components/schemas/answerData
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
        "400":
          description: Invalid Webhook
  "/api/v2/answer":
    get:
      tags[1]: Answers
      summary: Find a list of Answers by a set of filters
      description: Returns a list of Answers
      operationId: Answer-find
      parameters[15]:
        - name: _limit
          in: query
          description: Set the max number of objects to return
          required: false
          schema:
            type: number
            format: int64
        - name: _offset
          in: query
          description: Set the number of objects to ignore before starting
          required: false
          schema:
            type: number
            format: int64
        - name: _search
          in: query
          description: text string that will search certain text fields
          required: false
          schema:
            type: string
        - name: _select
          in: query
          description: "comma separated list of items to select ('tickets.*, ticketTypes.name')"
          required: false
          schema:
            type: string
        - name: questionId
          in: query
          description: questionId
          required: false
          schema:
            type: integer
            format: int64
        - name: answer
          in: query
          description: answer
          required: false
          schema:
            type: string
        - name: addOnAmount
          in: query
          description: addOnAmount
          required: false
          schema:
            type: integer
            format: float
        - name: ordering
          in: query
          description: ordering
          required: false
          schema:
            type: integer
            format: int64
        - name: quantityAvailable
          in: query
          description: quantityAvailable
          required: false
          schema:
            type: integer
            format: int64
        - name: showQuantity
          in: query
          description: showQuantity
          required: false
          schema:
            type: integer
            format: int64
        - name: oversell
          in: query
          description: oversell
          required: false
          schema:
            type: integer
            format: int64
        - name: minDynamicQuantity
          in: query
          description: minDynamicQuantity
          required: false
          schema:
            type: integer
            format: int64
        - name: maxDynamicQuantity
          in: query
          description: maxDynamicQuantity
          required: false
          schema:
            type: integer
            format: int64
        - name: vatPercentage
          in: query
          description: vatPercentage
          required: false
          schema:
            type: integer
            format: float
        - name: sku
          in: query
          description: sku
          required: false
          schema:
            type: string
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
    post:
      tags[1]: Answers
      summary: Create Answer
      description: Creates a new Answer from the POST data
      operationId: Answer-create
      requestBody:
        description: Input Data for Answer
        content:
          "application/json":
            schema:
              allOf[1]{"$ref"}:
                #/components/schemas/answerData
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
  "/api/v2/question/{questionId}/update-answer-localizations":
    post:
      tags[1]: Questions
      summary: Update a answer's localizations
      description: Updates a answer's localizations
      operationId: c9dd7e49c8f41139e65e41b914e7111d
      parameters[1]:
        - name: answerId
          in: path
          description: ID of the answer
          required: true
          schema:
            type: integer
            format: int64
      requestBody:
        description: Input data format
        content:
          "application/json":
            schema:
              properties:
                localizations:
                  description: The localizations for this answer
                  type: array
                  items:
                    type: string
              type: object
      responses:
        "200":
          "$ref": #/components/responses/ResultResponse
  "/api/v2/answer/sold":
    get:
      tags[1]: Answers
      summary: Get the number of sold items (pertaining to an answer or addOn)
      operationId: ed1fcdac80ea55d8db73cbe3289c37ef
      parameters[3]:
        - name: id
          in: query
          description: Id of answer to calculate sold count
          required: false
          schema:
            type: integer
            format: int64
        - name: eventId
          in: query
          description: Event to use in case the event has an answer override
          required: false
          schema:
            type: integer
            format: int64
        - name: cacheResult
          in: query
          description: Event to use in case the event has an answer override
          required: false
          schema:
            type: boolean
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
  "/api/v2/answer/remaining":
    get:
      tags[1]: Answers
      summary: Get the remaining number of items available ie. inventory (pertaining to an answer or addOn)
      operationId: 9685eb6d72eb7ab0a860e94be931c3ff
