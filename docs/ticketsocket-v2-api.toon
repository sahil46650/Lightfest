  responses:
    "200":
      description: The account has been updated.
    "400":
      description: An error occurred.
      content:
        "application/json":
          schema:
            allOf[1]{"$ref"}:
              #/components/schemas/error
    "401":
      description: The auth token is expired or none existings.
    ResultResponse:
      description: Success/failure and optional message
      content:
        "application/json":
          schema:
            properties:
              success:
                type: boolean
              message:
                type: string
              data:
                type: object
            type: object
    StringResponse:
      description: Single string response
      content:
        "application/json":
          schema:
            properties:
              value:
                type: string
            type: object
    CreateResponse:
      description: Single object response
      content:
        "application/json":
          schema:
            properties:
              id:
                type: int32
            type: object
    SingleResponse:
      description: Single object response
      content:
        "application/json":
          schema:
            properties:
              data:
                type: object
            type: object
    ListResponse:
      description: List of objects response
      content:
        "application/json":
          schema:
            properties:
              data:
                type: array
                items:
                  type: object
              count:
                type: integer
              totalCount:
                type: integer
              limit:
                type: integer
              offset:
                type: integer
            type: object
    ErrorResponse:
      description: An error occurred
      content:
        "application/json":
          schema:
            properties:
              message:
                type: string
              field:
                type: string
              detail:
                type: string
            type: object
  parameters:
    LimitParam:
      name: _limit
      in: query
      description: Limit number of returned results
      required: true
      schema:
        type: integer
        format: int32
        default: 200
        maximum: 500
        minimum: 10
        multipleOf: 10
    OffsetParam:
      name: _offset
      in: query
      description: "Offset results by skipping {offset} from the beginning of possible results"
      required: true
      schema:
        type: integer
        format: int32
        default: 0
        minimum: 0
  requestBodies:
    MyAccountGroupRouter:
      description: The customer's update information
      content:
        "application/json":
          schema:
            allOf[1]{"$ref"}:
              #/components/schemas/myInfo
  securitySchemes:
    bearerAuth:
      type: http
      name: bearerAuth
      in: header
      bearerFormat: JWT
      scheme: bearer
      openIdConnectUrl: "https://clevergroup.tscheckout.com/oauth2/authorization"
security[1]:
  - bearerAuth[0]:
