  "/api/v2/ticket":
    get:
      tags[1]: Tickets
      operationId: 36994e1551cdae7973cd2362fa7465b8
      parameters[13]:
        - name: orderId
          in: query
          description: Limit to tickets in this order
          required: false
          schema:
            type: string
        - name: eventId
          in: query
          description: Limit to tickets for this event
          required: false
          schema:
            type: string
        - name: typeId
          in: query
          description: Limit to tickets of this type
          required: false
          schema:
            type: string
        - name: customerId
          in: query
          description: Limit to tickets for this customer
          required: false
          schema:
            type: string
        - name: barcode
          in: query
          description: Limit to tickets matching this barcode
          required: false
          schema:
            type: string
        - name: search
          in: query
          description: Limit to tickets matching this search string
          required: false
          schema:
            type: string
        - name: purchasedFrom
          in: query
          description: Limit to tickets purchased after this date/time
          required: false
          schema:
            type: string
        - name: purchasedTo
          in: query
          description: Limit to tickets purchased before this date/time
          required: false
          schema:
            type: string
        - name: updatedFrom
          in: query
          description: Limit to tickets updated after this date/time
          required: false
          schema:
            type: string
        - name: updatedTo
          in: query
          description: Limit to tickets updated before this date/time
          required: false
          schema:
            type: string
        - name: _limit
          in: query
          description: Limit tickets to this number
          required: false
          schema:
            type: integer
            format: int64
        - name: _offset
          in: query
          description: Limit tickets to this number
          required: false
          schema:
            type: integer
            format: int64
        - name: _include
          in: query
          description: "Adds additional details to the results. Multiple options can be include seperated by a comma. Supports the following values:\n *  costs - Include costs details.\n *  refundProtect - Include refund protect information\n *  change - Include ticket id of new/old ticket.\n *  promoter - Include the ticket's promoter.\n *  waveTime - Include the wave time id (if any).\n *  waivers - Includes signed waivers attached to the ticket (if any).\n *  user - Include user information."
          required: false
          schema:
            type: string
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
