                properties:
                  count:
                    description: The number of objects contained in the data.
                    type: integer
                  data:
                    description: The data being returned.
                    type: array
                    items:
                      properties:
                        id:
                          description: The terminal's id.
                          type: string
                          example: tmr_F1gSbQ0RCw2Tpku
                        label:
                          description: Label identifing the terminal.
                          type: string
                        location:
                          description: The id for the location the terminal is at.
                          type: string
                          example: tml_F1gSKwAAB1Cw2T
                        serialNumber:
                          description: The serial number for the terminal.
                          type: string
                        status:
                          description: Current status of the terminal
                          type: string
                      type: object
                type: object
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
        "409":
          description: The account is not setup with stripe.
