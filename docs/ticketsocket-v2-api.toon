  "/api/v2/cart/build-cart-items":
    post:
      tags[1]: Cart
      summary: "From a json order description, build the cart items list"
      description: "Creates a line item for each ticket, question, insurance and fee (depending on settings)"
      operationId: buildCartItems
      requestBody:
        description: Input data format
        content:
          "application/json":
            schema:
              allOf[7]{"$ref"}:
                #/components/schemas/CartOptions
                #/components/schemas/BasicInfo
                #/components/schemas/CartData
                #/components/schemas/CartPromoCodes
                #/components/schemas/OrderAnswers
                #/components/schemas/ShippingOptions
                #/components/schemas/InsuranceInfo
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
        "400":
          "$ref": #/components/responses/ErrorResponse
  "/api/v2/cart/build-cart-items-from-order-id":
    get:
