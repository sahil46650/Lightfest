  "/api/v2/order/{id}":
    get:
      tags[1]: Orders
      summary: Returns a single order
      description: Returns a single order
      operationId: 53c1918033f5c9f25d60681cc95fc3b9
      parameters[4]:
        - name: id
          in: path
          description: The id of the order
          required: true
          schema:
            type: string
        - name: includeTickets
          in: query
          description: Set to true to include the ticket details.
          required: false
          schema:
            type: boolean
        - name: includeAnswers
          in: query
          description: Include any answer's for both the orders and tickets.
          required: false
          schema:
            type: boolean
        - name: includeCosts
          in: query
          description: Include costs as part of the order.
          required: false
          schema:
            type: boolean
      responses:
        "200":
          description: The order was found.
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/order
        "400":
          description: The order wasn't found.
  "/api/v2/order":
    get:
      tags[1]: Orders
      summary: Retrieves a list of orders.
      description: "Returns a list of order summaries. Note that filters apply to the orders, not the ticket. If you filter by an event and order has tickets for the filtered event and another both tickets will be returned."
      operationId: c25e42d2c65af9323d61594eab0fdb59
      parameters[33]:
        - name: _limit
          in: query
          description: Set the max number of objects to return.
          required: false
          schema:
            type: number
            format: integer
        - name: _offset
          in: query
          description: Set the number of objects to ignore before starting.
          required: false
          schema:
            type: number
            format: integer
        - name: search
          in: query
          description: "Searchs purchaser's first name, last name, email address as well as the ticket's barcode and order #."
          required: false
          schema:
            type: string
        - name: emailAddress
          in: query
          description: The email address of the purchaser.
          required: false
          schema:
            type: string
        - name: purchaseLocation
          in: query
          description: The location the order was purchased. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: string
        - name: eventSummary
          in: query
          description: The id of the event tickets where purchased for. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: integer
        - name: ticketType
          in: query
          description: The id of the ticket types that where purchased. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: integer
        - name: adminUser
          in: query
          description: The id of the user who sold the ticket. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: integer
        - name: event
          in: query
          description: The id of the event tickets where purchased for. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: integer
        - name: creditCardNumber
          in: query
          description: The last four of the CC used to pay for the order. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: string
        - name: bibNumber
          in: query
          description: Only include orders with a ticket that matches the bib number. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: string
        - name: paymentMethod
          in: query
          description: The payment method used to purchase the order.
          required: false
          schema:
            type: string
        - name: promoCode
          in: query
          description: The id's of the promo code that was applied to the order. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: integer
        - name: promoCodeGroup
          in: query
          description: The names's of the promo code group that was applied to the order. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: string
        - name: orderStatus
          in: query
          description: "Filter by the order's status. Acceptable values are active, cancelled, refunded, paritalCancelled, or partialRefunded."
          required: false
          schema:
            type: string
        - name: changeStatus
          in: query
          description: "Filter by the order change status. Acceptable values are transferred, upgraded, claimed, unclaimed, withdrawn, or eventChange."
          required: false
          schema:
            type: string
        - name: ticketStatus
          in: query
          description: "Filter by the ticket's status. Acceptable values are purchased, checkedIn, cancelled, or refunded."
          required: false
          schema:
            type: string
        - name: affiliate
          in: query
          description: The id of affilate associated with the order. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: integer
        - name: shippingMethod
          in: query
          description: Filter by the shipping method id.
          required: false
          schema:
            type: number
        - name: purchasedWithPass
          in: query
          description: Pass true to limit search for to orders that were purchased with a pass.
          required: false
          schema:
            type: bool
        - name: refundProtect
          in: query
          description: "Filters based on if refund proctected was purchased and type. Supports the following values opted-in, opted-out, meetch, or refundProtect."
          required: false
          schema:
            type: boolean
        - name: fromPurchaseDate
          in: query
          description: The earliest date the order was purchased.
          required: false
          schema:
            type: string
        - name: toPurchaseDate
          in: query
          description: The latest date the order was purchased.
          required: false
          schema:
            type: string
        - name: fromLastUpdate
          in: query
          description: The earliest date the order was updated.
          required: false
          schema:
            type: string
        - name: toLastUpdate
          in: query
          description: The latest date the order was updated.
          required: false
          schema:
            type: string
        - name: fromTicketPrice
          in: query
          description: The lowest listed price for a ticket when purchased.
          required: false
          schema:
            type: number
        - name: toTicketPrice
          in: query
          description: The highest lised price for a ticket when purchased.
          required: false
          schema:
            type: number
        - name: fromCurrentTicketPrice
          in: query
          description: The lowest price currently paid for a ticket.
          required: false
          schema:
            type: number
        - name: toCurrentTicketPrice
          in: query
          description: The highest price currently paid for a ticket.
          required: false
          schema:
            type: number
        - name: fromTicketPricePaid
          in: query
          description: The lowest price originally paid for a ticket.
          required: false
          schema:
            type: number
        - name: toTicketPricePaid
          in: query
          description: The highest price originally paid for a ticket.
          required: false
          schema:
            type: number
        - name: return
          in: query
          description: "Select the format of the returned data. If the parameter is not provided the default format is standard. Can be one of the following:\n *  attendees - A csv containing the list of matching attendees.\n *  purchasers - A csv containing the list of matching purchasers.\n * \ttickets - A csv containing the list of matching tickets.\n *  orders - A csv contain the list of matching orders.\n *  shipping - A csv contain shipping information for the matching orders.\n *  standard - Json contain the selected data."
          required: false
          schema:
            type: string
        - name: _include
          in: query
          description: "Adds additional details to the results. Ignored if format is any other then standard. Multiple options can be include seperated by a comma. Supports the following values:\n *  answers - Include answers to questions.\n *  tickets - Include ticket information.\n *  promoCodes - Include promo codes used.\n *  hash - Include order hash.\n *  costs - Include cost information.\n *  purchaseProtected - Include purchase protect information.\n *  allTicketsForOrder - Include all tickets for order ignoring fileters.\n *  ticketCount - Include the number of tickets per order.\n *  change - Include orders id of new/old orders.\n *  promoter - Include the ticket's promoter.\n *  waveTime - Include the wave time id (if any).\n *  waivers - Includes signed waivers attached to the ticket (if any).\n *  user - Include user information."
          required: false
          schema:
            type: string
      responses:
        "200":
          description: A list of matching orders.
    post:
      tags[1]: Orders
      summary: Creates an order once payment has been verified.
      description: Creates an order based on the cart created via the shopping cart end points. The order is only created after payment has been verified.
      operationId: 40f4eaa4acaae05b788c1e4ab8f6bc2d
      requestBody:
        description: The tickets to remove.
        content:
          "application/json":
            schema:
              required[1]: order
              properties:
                order:
                  description: The cart created via the shopping cart. Payment process has to have been started.
                  type: string
              type: object
      responses:
        "200":
          description: The order was created after payment was successfully. The order is only included if result is order.
          content:
            "application/json":
              schema:
                properties:
                  id:
                    description: The id of the new order.
                    type: string
                  order:
                    "$ref": #/components/schemas/cartResponse
                type: object
        "202":
          description: The payment processor hasn't successfully processed payment yet.
          content:
            "application/json":
              schema:
                properties:
                  status:
                    description: "Status returned by the payment processor. Can be error, failed, cancled, processing, or verify."
                    type: string
                  token:
                    description: A token returned by the payment processor to allow for additional verification.
                    type: string
                type: object
        "204":
          description: The order was created after payment was successfully. Returned if result is set to none.
        "400":
          description: An error occurred.
          content:
            "application/json":
              schema:
                "$ref": #/components/schemas/error
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
        "409":
          description: The payment process hasn't started.
        "410":
          description: The cart timer has expired.
