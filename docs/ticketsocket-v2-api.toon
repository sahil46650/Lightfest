    promoCodeTagPricePair:
      properties:
        tag:
          description: Tag that the corresponding price applies to
          type: string
          example: flex20
        price:
          description: Amount of discount per tag
          example: "12.00"
      type: object
    promoCodeData:
      properties:
        code:
          description: Code used to reference this storedValueCode
          type: string
          example: Thanksgiving-25PercentPromo
        type:
          description: "Type of PromoCode - flat, percentage, specific or specificTag"
          type: string
          example: flat
        promoCodeTagPricePair:
          description: Applies only to specificTag types and defines the amount an item with a specific tag is discounted
          type: array
          items:
        discount:
          description: Amount of value applied
          example: "28.00"
        active:
          description: Defines if the Code is active or not
          type: boolean
          example: true or false
        activeFrom:
          description: Timestamp (in UTC) of the time when this code becomes active (often right away)
          example: "1704067200"
        activeTo:
          description: Timestamp (in UTC) of the time when this code becomes inactive or expires
          example: "1704067200"
        description:
          description: Code description
          type: string
          example: Credit provided for excellent attendance
        promoter:
          description: Optional promoterId
          example: "30385"
        usesLimit:
          description: Maximum number of times a promoCode can be used
          example: "8"
        userUsesLimit:
          description: Maximum number of times a specific user can use a promoCode
          example: "2"
        codeGroup:
          description: Code Group - like a category used to organize promoCodes
          type: string
          example: Triathlon Discount Codes
        minQuantity:
          description: Minimum Quantity
          example: "2"
        discountAddOns:
          description: Allow code to apply to AddOns
          type: boolean
          example: "1"
        discountShipping:
          description: Allow code to apply to Shipping
          type: boolean
          example: "1"
        passId:
          description: "If this code is a Pass, the id of the Pass Ticket"
          example: "54888"
        transferTicketId:
          description: "If this code was generated from a ticket transfer, the id of the ticket that was transferred"
          example: "33892"
      type: object
    questionData:
      properties:
        name:
          description: Name of the question
          type: string
          example: Emergency Contact
        question:
          description: The question to show the customer
          type: string
          example: Emergency Contact Name
        type:
          description: The type of the question
          type: string
          enum[6]: text,multiple,multipleDynamicQuantity,multipleRadio,multipleSearch,multipleCheckbox
        required:
          description: Whether the question is required or not
          type: boolean
          default: false
        specialFormat:
          description: Special formatting rules for text questions
          type: string
          enum[3]: text,datePickerNa,datePickerEu
        enablePrice:
          description: Whether the answers can have a price
          type: boolean
          default: false
        enableQuantity:
          description: Whether the answers can have a limited quantity
          type: boolean
          default: false
        moreInfoEnabled:
          description: Whether the question displays the more info content
          type: boolean
          default: false
        moreInfoTextAbove:
          description: The more info content displayed above the question
          type: string
        moreInfoTextBelow:
          description: The more info content displayed below the question
          type: string
      type: object
