  "/api/v2/custom-dashboard":
    get:
      tags[1]: Custom Dashboard
      summary: Get custom dashboards
      description: Get custom dasbhboards
      operationId: 723de196850074a805627725e20f9c6e
      parameters[3]:
        - name: _limit
          in: query
          description: Set the max number of custom dashboards to return.
          required: false
          schema:
            type: number
            format: integer
        - name: _offset
          in: query
          description: Set the number of objects to ignore before starting.
          required: false
          schema:
            type: number
            format: integer
        - name: permissions
          in: query
          description: Whether we'd like the custom dashboard permissions for user making request.
          required: false
          schema:
            type: boolean
      responses:
        "200":
          description: A list of custom dashboards user has access too.
        "400":
          description: One or more errors occurred.
        "401":
          description: The auth token is expired or none existing.
