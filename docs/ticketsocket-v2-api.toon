                  description: Process state
                  type: integer
                transferState:
                  description: Transferred state
                  type: string
                upgradeState:
                  description: Upgraded state
                  type: string
                deleted:
                  description: Is deleted
                  type: integer
              type: object
      responses:
        "200":
          "$ref": #/components/responses/ResultResponse
  "/api/v2/ticket-type/":
    get:
      tags[1]: Ticket Types
      operationId: 4626a5168320988c27c8ec29e03d7c85
      parameters[10]:
        - parameter: name
          name: name
          in: query
          description: "Search text in the name - add % as wildcard, for instance: %smart% will find any Ticket Type with smart in the name"
          required: false
          schema:
            type: string
        - parameter: eventId
          name: eventId
          in: query
          description: "Find all Ticket Types associated with a specific event Id. Multiple values can be provided seperated by commas. "
          required: false
          schema:
            type: integer
            format: int64
        - parameter: waveTime
          name: waveTime
          in: query
          description: "Only returns tickets with the associated wave times. Multiple values can be provided seperated by commas. "
          required: false
          schema:
            type: integer
            format: int64
        - parameter: key
          name: key
          in: query
          description: "Search text in the key - use % as wildcard, for instance: %smart% will find any Ticket Type with smart in the key"
          required: false
          schema:
            type: string
        - parameter: groupKey
          name: groupKey
          in: query
          description: "Search text in the groupKey - use % as wildcard, for instance: %smart% will find any Ticket Type with smart in the groupKey"
          required: false
          schema:
            type: string
        - parameter: updatedSince
          name: updatedSince
          in: query
          description: Returns ticket types that have been changed since the provided date. The date is a unix timestamp.
          required: false
          schema:
            type: int
        - name: _include
          in: query
          description: "Adds additional details to the results. Supports the following values:\n *  tags - Include tags.\n *  sold - Include the number of tickets sold.\n *  waveTimes - Include wave times.\n *  shipping - Include shipping methods.\n *  bulkDiscount - Include bulk discounts."
          required: false
          schema:
            type: string
        - name: _orderBy
          in: query
          description: "Determins the order the events are returned. Each property can be append with + or -. + indicated sort asc and - sorts deciding. If excluded the column is sorted in asceding sort. Multiple columns a seperated by a comma. You can sort by ordering, name, id."
          required: false
          schema:
            type: string
        - name: _limit
          in: query
          description: Limit Results to this number
          required: false
          schema:
            type: integer
            format: int64
        - name: _offset
          in: query
          description: Limit Results to this number
          required: false
          schema:
            type: integer
            format: int64
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
