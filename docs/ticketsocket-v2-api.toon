                #/components/schemas/InsuranceInfo
      responses:
        "200":
          "$ref": #/components/responses/ResultResponse
  "/api/v2/check-in/tickets":
    get:
      tags[1]: Check-In
      summary: Get ticket data for scanning purposes
      operationId: 60375975f4c12372edf7af56e7dce11e
      parameters[12]:
        - name: orderId
          in: query
          description: Limit to tickets in this order
          required: false
          schema:
            type: string
        - name: eventId
          in: query
          description: Limit to tickets for this event
          required: false
          schema:
            type: string
        - name: typeId
          in: query
          description: Limit to tickets of this type
          required: false
          schema:
            type: string
        - name: customerId
          in: query
          description: Limit to tickets for this customer
          required: false
          schema:
            type: string
        - name: barcode
          in: query
          description: Limit to tickets matching this barcode
          required: false
          schema:
            type: string
        - name: search
          in: query
          description: Limit to tickets matching this search string
          required: false
          schema:
            type: string
        - name: purchasedFrom
          in: query
          description: Limit to tickets purchased after this date/time
          required: false
          schema:
            type: string
        - name: purchasedTo
          in: query
          description: Limit to tickets purchased before this date/time
          required: false
          schema:
            type: string
        - name: updatedFrom
          in: query
          description: Limit to tickets updated after this date/time
          required: false
          schema:
            type: string
        - name: updatedTo
          in: query
          description: Limit to tickets updated before this date/time
          required: false
          schema:
            type: string
        - name: limit
          in: query
          description: Limit tickets to this number
          required: false
          schema:
            type: integer
            format: int64
        - name: offset
          in: query
          description: Limit tickets to this number
          required: false
          schema:
            type: integer
            format: int64
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
