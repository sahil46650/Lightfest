          required: true
          schema:
            type: string
        - name: _limit
          in: query
          description: Set the max number of fgl commands to return.
          required: false
          schema:
            type: number
            format: integer
        - name: _offset
          in: query
          description: Set the number of objects to ignore before starting.
          required: false
          schema:
            type: number
            format: integer
