  "/api/v2/upload":
    post:
      tags[1]: Upload
      operationId: f365115bce7f0697a0c2f1b479e0c44a
      requestBody:
        description: The file to upload.
        content:
          "application/json":
            schema:
              required[2]: area,item
              properties:
                area:
                  description: "The area is upload if for. Current only \\"settings\\" is supported."
                  type: string
                item:
                  description: The item within the area the upload is for.
                  type: string
                file:
                  description: The file to be uploaded. If the file isn't included the existing file is deleted.
                  required[2]: name,data
                  properties:
                    name:
                      description: The name of the file.
                      type: string
                    data:
                      description: The base64 encoded contents of the file to uploaded.
                      type: string
                  type: object
              type: object
          "multipart/form-data":
            schema:
              required[3]: area,item,file
              properties:
                area:
                  description: "The area is upload if for. Current only \\"settings\\" is supported."
                  type: string
                item:
                  description: The item within the area the upload is for.
                  type: string
                file:
                  description: The file to be uploaded.
                  type: string
                  format: binary
              type: object
      responses:
        "200":
          description: The file was succesfully uploaded.
          content:
            "application/json":
              schema:
                properties:
                  count:
                    description: The number of object's contained in the result.
                    type: integer
                  data:
                    description: The records contained in the results.
                    properties:
                      url:
                        description: The url where the resource can be accessed
                        type: string
                    type: object
                type: object
        "400":
          description: One or more errors occurred.
          content:
            "application/json":
              schema:
                "$ref": #/components/schemas/error
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
        "503":
          description: The file failed to save. Try again later.
    delete:
      tags[1]: Upload
      operationId: c6cb86b6e9879b682a94e0b730b9b3c7
      requestBody:
        description: The file to be deleted.
        content:
          "application/json":
            schema:
              required[2]: area,item
              properties:
                area:
                  description: "The area is to delete the file. Current only \\"settings\\" is supported."
                  type: string
                item:
                  description: The item within the area to delete the file.
                  type: string
              type: object
      responses:
        "207":
          description: The file was succesfully uploaded.
          content:
            "application/json":
              schema:
                properties:
                  count:
                    description: The number of object's contained in the result.
                    type: integer
                  data:
                    description: The records contained in the results.
                    type: array
                    items:
                      properties:
                        item:
                          description: The item this response corresponds with.
                          type: string
                        status:
                          description: The https status code for the result
                          type: string
                        object:
                          description: If successful the resulting data.
                          properties:
                            url:
                              description: The url the file uploaded can be accessed at.
                              type: string
                          type: object
                        error:
                          "$ref": #/components/schemas/error
                      type: object
                type: object
        "400":
          description: One or more errors occurred.
          content:
            "application/json":
              schema:
                "$ref": #/components/schemas/error
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
        "503":
          description: The file failed to save. Try again later.
  "/api/v2/upload/bulk":
    post:
      tags[1]: Upload
      operationId: 02897205e28c6db3a84b5d18a424d92d
      requestBody:
        description: The file to upload.
        content:
          "application/json":
            schema:
              required[2]: area,items
              properties:
                area:
                  description: "The area is upload if for. Current only \\"settings\\" is supported."
                  type: string
                items:
                  description: The list of item's within the area the upload is for.
                  type: array
                  items:
                    required[1]: item
                    properties:
                      item:
                        description: The name of the item.
                        type: string
                      file:
                        description: The file to be uploaded. If the file isn't included the existing file is deleted.
                        required[2]: name,data
                        properties:
                          name:
                            description: The name of the file.
                            type: string
                          data:
                            description: The base64 encoded contents of the file to uploaded.
                            type: string
                        type: object
                    type: object
              type: object
          "multipart/form-data":
            schema:
              required[3]: area,"items[]","{item}"
              properties:
                area:
                  description: "The area is upload if for. Current only \\"settings\\" is supported."
                  type: string
                "items[]":
                  description: The list of item within the area the upload is for.
                  type: string
                "{item}":
                  description: The file to be uploaded. The name should match name of the items.
                  type: string
                  format: binary
              type: object
      responses:
        "207":
          description: The file was succesfully uploaded.
          content:
            "application/json":
              schema:
                properties:
                  count:
                    description: The number of object's contained in the result.
                    type: integer
                  data:
                    description: The records contained in the results.
                    type: array
                    items:
                      properties:
                        item:
                          description: The item this response corresponds with.
                          type: string
                        status:
                          description: The https status code for the result
                          type: string
                        object:
                          description: If successful the resulting data.
                          properties:
                            url:
                              description: The url the file uploaded can be accessed at.
                              type: string
                          type: object
                        error:
                          "$ref": #/components/schemas/error
                      type: object
                type: object
        "400":
          description: One or more errors occurred.
          content:
            "application/json":
              schema:
                "$ref": #/components/schemas/error
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
        "503":
          description: The file failed to save. Try again later.
