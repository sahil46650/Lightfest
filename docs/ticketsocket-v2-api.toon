          required: false
          schema:
            type: integer
            format: int64
        - name: eventId
          in: query
          description: Event to use in case the event has an answer override
          required: false
          schema:
            type: integer
            format: int64
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
  "/api/v2/docs.json":
    get:
