                    description: The data being returned.
                    properties:
                      token:
                        description: The token return by Stripe need to authorize the SDK.
                        type: string
                    type: object
                type: object
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
        "409":
          description: The account is not setup with stripe.
  "/api/v2/payment-processor/stripe/terminal":
    get:
      tags[1]: Payment Processors
      summary: Return the list of terminals associted with the stripe account.
      operationId: 1fd6a3c3df70cc43dc589e984755dd32
      responses:
