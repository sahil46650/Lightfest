    storedValueData:
      properties:
        code:
          description: Code used to reference this storedValueCode
          type: string
          example: RefundCredit-SamGoodman-Order12
        discount:
          description: Amount of value applied
          example: "28.00"
        active:
          description: Defines if the Code is active or not
          type: boolean
          example: true or false
        activeFrom:
          description: Timestamp (in UTC) of the time when this code becomes active (often right away)
          example: "1704067200"
        activeTo:
          description: Timestamp (in UTC) of the time when this code becomes inactive or expires
          example: "1704067200"
        description:
          description: Code description
          type: string
          example: Credit provided for excellent attendance
      type: object
