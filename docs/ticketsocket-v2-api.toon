      operationId: Settings-find
      parameters[6]:
        - name: _limit
          in: query
          description: Set the max number of objects to return
          required: false
          schema:
            type: number
            format: int64
        - name: _offset
          in: query
          description: Set the number of objects to ignore before starting
          required: false
          schema:
            type: number
            format: int64
        - name: _search
          in: query
          description: "This will only return setting names that contain the string supplied. You can search for multiple values by using a comma (',') as a seperator"
          required: false
          schema:
            type: string
        - name: name
          in: query
          description: search by setting name
          required: false
          schema:
            type: string
        - name: value
          in: query
          description: search by setting value
          required: false
          schema:
            type: string
        - name: groupSearch
          in: query
          description: group search can search for multiple values separated by comma and will return all settings within each setting group
          required: false
          schema:
            type: string
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
