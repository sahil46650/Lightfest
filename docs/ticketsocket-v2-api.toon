          in: query
          description: "Determines the format of repsonse. If not provided the default is id. Can be one of the following values:<ul><li>none - no body is returned.</li><li>id - The id of the customer is returend.</li><li>object - The entire object is returned.</li></ul>"
          required: false
          schema:
            type: string
      requestBody:
        content:
          "application/json":
            schema:
              properties:
                description:
                  description: The description for the wave time.
                  type: string
                ordering:
                  description: The order the wave time should appear.
                  type: integer
                startTimestamp:
                  description: The date/time the wave time starts (in unix time).
                  type: integer
                quantity:
                  description: The maxiume number of tickets that can be assigned to this wave time.
                  type: integer
                instructions:
                  description: Any instructions for the wave time
                  type: string
                allowSalesMinutesPastStartTime:
                  description: The number of minutes past the start tickets can still be sold. Set to zero if sales stop when the wave time starts.
                  type: integer
                types:
                  description: The ids of the ticket types this wave time is limited to. If provided then all current tickets types are removed before the new list is applied.
                  type: array
                  items:
                    type: string
              type: object
      responses:
        "200":
          description: Information concerning the deleted wave time.
          content:
            "application/json":
              schema:
                "$ref": #/components/schemas/waveTimeResponse
        "400":
          "$ref": #/components/responses/ErrorResponse
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
  "/api/v2/webhook/{id}":
    get:
      tags[1]: Webhooks
      summary: Find Webhook by Id
      description: Returns a single Webhook
      operationId: Webhook-findOne
      parameters[1]:
        - name: id
          in: path
          description: id
          required: true
          schema:
            type: integer
            format: int64
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
        "400":
          description: Invalid Webhook
    delete:
      tags[1]: Webhooks
      summary: Delete one Webhook by Id
      description: Deletes the identified Webhook
      operationId: Webhook-delete
      parameters[1]:
        - name: id
          in: path
          description: id
          required: true
          schema:
            type: integer
            format: int64
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
        "400":
          description: Invalid Webhook
    patch:
      tags[1]: Webhooks
      summary: Update Webhook by Id
      description: Updates an existing Webhook from the PATCH data
      operationId: Webhook-update
      parameters[1]:
        - name: id
          in: path
          description: id
          required: true
          schema:
            type: integer
            format: int64
      requestBody:
        description: Input Data for Webhook
        content:
          "application/json":
            schema:
              allOf[1]{"$ref"}:
                #/components/schemas/WebhookData
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
        "400":
          description: Invalid Webhook
  "/api/v2/webhook":
    get:
      tags[1]: Webhooks
      summary: Find a list of Webhooks by a set of filters
      description: Returns a list of Webhooks
      operationId: Webhook-find
      parameters[7]:
        - name: _limit
          in: query
          description: Set the max number of objects to return
          required: false
          schema:
            type: number
            format: int64
        - name: _offset
          in: query
          description: Set the number of objects to ignore before starting
          required: false
          schema:
            type: number
            format: int64
        - name: _search
          in: query
          description: text string that will search certain text fields
          required: false
          schema:
            type: string
        - name: _select
          in: query
          description: "comma separated list of items to select ('tickets.*, ticketTypes.name')"
          required: false
          schema:
            type: string
        - name: type
          in: query
          description: type
          required: false
          schema:
            type: string
        - name: display
          in: query
          description: display
          required: false
          schema:
            type: string
        - name: objectType
          in: query
          description: objectType
          required: false
          schema:
            type: string
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
    post:
      tags[1]: Webhooks
      summary: Create Webhook
      description: Creates a new Webhook from the POST data
      operationId: Webhook-create
      requestBody:
        description: Input Data for Webhook
        content:
          "application/json":
            schema:
              allOf[1]{"$ref"}:
                #/components/schemas/WebhookData
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
  "/api/v2/webhook/run":
    get:
      tags[1]: Webhooks
      summary: Run a Webhook of a specific type
      description: Runs the enabled webhooks of a specific type on the referenceId
      operationId: Webhook-runOne
      parameters[2]:
        - name: type
          in: query
          description: "Webhook type (should be one of these): orderComplete, attendeeCheckinComplete, ticketClaimComplete, ticketCancelComplete, orderCancelComplete, informationChangeComplete, orderRefundComplete, orderInformationChangeComplete"
          required: true
          schema:
            type: string
        - name: referenceId
          in: query
          description: "should be the order Id for all types except attendeeCheckinComplete, ticketClaimComplete and ticketCancelComplete in which case it should be the ticketId"
          required: false
          schema:
            type: string
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
        "400":
          description: Invalid Webhook
components:
  schemas:
    answerObject:
      properties:
        questionId:
          description: questionId
          type: integer
          example: "1015"
        answer:
          description: answer
          type: string
          example: String
        addOnAmount:
          description: addOnAmount
          example: "42.86"
        ordering:
          description: ordering
          type: integer
          example: "1015"
        quantityAvailable:
          description: quantityAvailable
          type: integer
          example: "1015"
        showQuantity:
          description: showQuantity
          type: integer
          example: "1015"
        oversell:
          description: oversell
          type: integer
          example: "1015"
        minDynamicQuantity:
          description: minDynamicQuantity
          type: integer
          example: "1015"
        maxDynamicQuantity:
          description: maxDynamicQuantity
          type: integer
          example: "1015"
        vatPercentage:
          description: vatPercentage
          example: "42.86"
        sku:
          description: sku
          type: string
          example: MySku34
      type: object
    answerData:
      properties:
        data:
          "$ref": #/components/schemas/answerObject
      type: object
    limitOffsetFilters:
      properties:
        limit:
          description: Limit results
          type: integer
          default: 500
        offset:
          description: Offset results
          type: integer
          default: 0
      type: object
    BibAssignmentRuleObject:
      properties:
        name:
          description: name
          type: string
          example: String
        bibStart:
          description: bibStart
          type: integer
          example: "1015"
        bibEnd:
          description: bibEnd
          type: integer
          example: "1015"
        prefix:
          description: prefix
          type: string
          example: String
        suffix:
          description: suffix
          type: string
          example: String
        assignmentTime:
          description: assignmentTime
          type: string
          example: String
        chipAssignment:
          description: chipAssignment
          type: string
          example: String
        chipAssignmentFile:
          description: chipAssignmentFile
          type: string
          example: String
        lastUpdated:
          description: lastUpdated
          type: integer
          example: "1015"
        archived:
          description: archived
          type: integer
          example: "1015"
      type: object
    BibAssignmentRuleData:
      properties:
        data:
          "$ref": #/components/schemas/BibAssignmentRuleObject
      type: object
    CartOptions:
      properties:
        includeFees:
          description: Add Fees to Line Items or as Line Items depending on settings
          type: integer
      type: object
    ConnectJobObject:
      properties:
        submitTime:
          description: submitTime
          type: dateTime
          example: "2025-10-06 08:33:03"
        type:
          description: ConnectJob Type Id
          type: string
          example: String
        eventId:
          description: eventId
          type: integer
          example: "1015"
        eventAuto:
          description: Auto created Event Connect Job
          type: boolean
          example: "false"
        filters:
          description: Filter info for Job
          type: string
          example: "{'sendTo':'sendToUnclaimed','eventId':'101958'}"
        name:
          description: Name of Job
          type: string
          example: Send Email Job to Easy Event at 2024-07-01
        emailTemplateId:
          description: Email Template Id to use when sending
          type: integer
          example: "12"
        startTime:
          description: Time to start sending emails
          type: dateTime
          example: "2025-10-25 22:00:00"
        typeIds:
          description: List of TypeIds to filter on
          type: string
          example: "1075,6489"
      type: object
    ConnectJobData:
      properties:
        data:
          "$ref": #/components/schemas/ConnectJobObject
      type: object
    customDashboard:
      properties:
        name:
          type: string
        url:
          type: string
        anyUser:
          type: boolean
      type: object
    id:
      properties:
        data:
          description: id of custom dashboard
          type: integer
      type: object
    address:
      properties:
        street:
          type: string
        street2:
          type: string
        city:
          type: string
        zip:
          type: string
        phone:
          type: string
        country:
          type: string
        internationalAddress:
          type: string
      type: object
    name:
      properties:
        first:
          type: string
        last:
          type: string
      type: object
    facebook:
      properties:
        id:
          type: string
        info:
          type: string
        userId:
          type: string
      type: object
    person:
      properties:
        name:
          "$ref": #/components/schemas/name
        address:
          "$ref": #/components/schemas/address
        phone:
          description: Person's phone.
          type: string
        suburb:
          description: The suburb the person lives
          type: string
      type: object
    user:
      properties:
        id:
          description: The id of the ticket
          type: string
        guid:
          type: string
          example: active
        externalId:
          description: External id associated with the account
          type: string
        accountNumber:
          description: Account number associated with the account
          type: string
        username:
          type: string
        emailAddress:
          description: User's email address
          type: string
        customer:
          "$ref": #/components/schemas/person
        billing:
          "$ref": #/components/schemas/person
        company:
          description: Users company name.
          type: string
        dateOfBirth:
          description: User's date of birth.
          type: string
        facebook:
          "$ref": #/components/schemas/facebook
        created:
          description: When the user was created.
          type: integer
        lastUpdated:
          description: When the user was last update.
          type: integer
        associateKeyValue:
          type: string
        emergencyContactName:
          description: Name of user's emergency contact.
          type: string
        emergencyContactPhone:
          description: Phone number for user's emergency contact.
          type: string
      type: object
    object:
      properties:
        data:
          "$ref": #/components/schemas/user
        count:
          description: Nuumber of customers include in the response.
          type: integer
      type: object
    customerId:
      properties:
        data:
          description: The id of customer updated.
          type: integer
        count:
          description: Number of customers include in the response.
          type: integer
      type: object
    error:
      properties:
        data:
          description: The error that occurred.
          properties:
            field:
              description: The name of the field if applicable.
              type: integer
            message:
              description: The error message.
              type: integer
          type: object
        count:
          description: Number of errors that occurred.
          type: integer
      type: object
    userList:
      properties:
        totalCount:
          description: Total number of orders in the system that match the filters.
          type: integer
        count:
          description: Nuumber of orders include in the response.
          type: integer
        limit:
          description: The maximum number of orders to return.
          type: integer
        offset:
          description: The first order to return.
          type: integer
        data:
          description: The list of customers.
          type: array
          items:
            allOf[1]{"$ref"}:
              #/components/schemas/user
      type: object
    substitutionArrayType:
      type: array
      items:
        type: array
        items:
          "$ref": #/components/schemas/substitutionPair
    substitutionPair:
      properties:
        propName:
          description: PropertyName to be substituted
          type: string
          example: FirstName
        value:
          description: value to replace the delimited propName in substitution
          type: string
          example: Jones
      type: object
    emailWithTemplateData:
      properties:
        to:
          description: Email address to send email to
        templateName:
          description: Template Name
        templateType:
          description: templateType
        substitutionArray:
          description: Substitution Array (array of name/value pairs) - names will be replaced with value when surrounded by delimiters
        delimiters:
          description: Delimiters
      type: object
    venue:
      properties:
        name:
          description: The name of the venue.
          type: string
        address:
          "$ref": #/components/schemas/address
      type: object
    event:
      properties:
        id:
          description: The id of the event.
          type: string
        title:
          description: The name of the event.
          type: string
        start:
          description: The unix date/time the event start.
          type: string
        venue:
          "$ref": #/components/schemas/venue
        cutOff:
          description: The timestamp (in UTC) when sales should be cutoff for this event
          example: "1702378800"
        onSaleDate:
          description: Timestamp (in UTC) representing when the date that tickets can start selling for this event
          example: "1702278800"
        publishedDate:
          description: "This is the timestamp (in UTC) that an event will become published. If the date is not set to published but this date is set is in the past, the evnt will be published. If the event is already set to published, this has no effect"
          example: ""
        published:
          description: "When published (and onSale), the event will show up on the frontend UI - 0 for no, 1 for yes - defaults to 0"
          example: ""
        hideDate:
          description: "Should the Event Date be hidden from the UI - 0 for no, 1 for yes - defaults to 0"
          example: "0"
        hideTime:
          description: "Should the Event Time be hidden from the UI? - 0 for no, 1 for yes - defaults to 0"
          example: "0"
        smallPic:
          description: Smaller picture URL that will be shown on the Event List
          example: ""
        largePic:
          description: Larger picture URL that will be displayed on the Event Details page
          example: ""
        shortDescription:
          description: Short description of the event
          example: Super Race Event in San Francisco
        category:
          description: Category number of event for when events use the category option
          example: ""
        ordering:
          description: Defines a relative number compare to other events to determine the order they will be displayed. Smaller is sooner in the list.
          example: "50"
        location:
          description: Location Name where event will be held
          example: Central Park
        sefUrl:
          description: "Slug (event Url) - must be a valid URL. If not provided, one will be generated from the title"
          example: my-event-12-12-2023
        timezone:
          description: "A valid timezone ID to apply to the event - see database <a href='https://www.iana.org/time-zones'>Time Zone Database</a>"
          example: EST or Europe/Paris
        inventory:
          description: Number of tickets availables. Only included if requested.
          properties:
            sold:
              description: The number of tickets sold.
              type: number
            total:
              description: Total tickets available. Can be null if the number of available tickets can't be determined.
              type: number
          type: object
      type: object
    eventList:
      properties:
        totalCount:
          description: Total number of events in the system that match the filters.
          type: integer
        count:
          description: Nuumber of evemts include in the response.
          type: integer
        limit:
          description: The maximum number of events to return.
          type: integer
        offset:
          description: The first event to return.
          type: integer
        data:
          description: The list of events.
          type: array
          items:
            allOf[1]{"$ref"}:
              #/components/schemas/event
      type: object
    eventData:
      properties:
        title:
          description: Title or Name of the event
          type: string
          example: "My Race Event December 12th, 2023"
        start:
          description: Timestamp (in UTC) of the event Start time
          example: "1702382400"
        end:
          description: Timestamp (in UTC) of the event End time
          example: "1702404000"
        cutOff:
          description: The timestamp (in UTC) when sales should be cutoff for this event
          example: "1702378800"
        onSaleDate:
          description: Timestamp (in UTC) representing when the date that tickets can start selling for this event
          example: "1702278800"
        publishedDate:
          description: "This is the timestamp (in UTC) that an event will become published. If the date is not set to published but this date is set is in the past, the evnt will be published. If the event is already set to published, this has no effect"
          example: ""
        published:
          description: "When published (and onSale), the event will show up on the frontend UI - 0 for no, 1 for yes - defaults to 0"
          example: ""
        hideDate:
          description: "Should the Event Date be hidden from the UI - 0 for no, 1 for yes - defaults to 0"
          example: "0"
        hideTime:
          description: "Should the Event Time be hidden from the UI? - 0 for no, 1 for yes - defaults to 0"
          example: "0"
        smallPic:
          description: Smaller picture URL that will be shown on the Event List
          example: ""
        largePic:
          description: Larger picture URL that will be displayed on the Event Details page
          example: ""
        shortDescription:
          description: Short description of the event
          example: Super Race Event in San Francisco
        category:
          description: Category number of event for when events use the category option
          example: ""
        ordering:
          description: Defines a relative number compare to other events to determine the order they will be displayed. Smaller is sooner in the list.
          example: "50"
        location:
          description: Location Name where event will be held
          example: Central Park
        sefUrl:
          description: "Slug (event Url) - must be a valid URL. If not provided, one will be generated from the title"
          example: my-event-12-12-2023
        timezone:
          description: "A valid timezone ID to apply to the event - see database <a href='https://www.iana.org/time-zones'>Time Zone Database</a>"
          example: EST or Europe/Paris
        venue:
          description: Name for the venue where the event will be held
          example: ""
        showVenue:
          description: Make venue visible on event page
          example: ""
        venueAddress1:
          description: Line 1 of the Venue address
          example: ""
        showAddress1:
          description: Make venue address1 visible on event page
          example: ""
        venueAddress2:
          description: Line 2 of the Venue address
          example: ""
        showVenueAddress2:
          description: Make venue address2 visible on event page
          example: ""
        venueCity:
          description: City of the venue for the event
          example: ""
        showVenueCity:
          description: Make venue address2 visible on event page
          example: ""
        venueState:
          description: State of the venue for the event
          example: ""
        showVenueState:
          description: Make venue state visible on event page
          example: ""
        venueCountry:
          description: Country of the venue for the event
          example: ""
        venuePostalCode:
          description: PostalCode/Zip of the venue for the event
          example: ""
        showVenuePostalCode:
          description: Make Venue postalCode visible on event page
          example: ""
        alias:
          description: An alternative name for the Event
          example: ""
        ages:
          description: Appropriate ages for event (not enforced)
          example: ""
        capacity:
          description: Capacity of the event
        externalId:
          description: A reference to an external Event Id
        latitude:
          description: Latitude of the event location
        longitude:
          description: Longitude of the event location
        waiverId:
          description: Custom Waiver Id for this event
        dayOfWaiverId:
          description: Custom Day of Event Waiver Id
        showUpcomingPriceRuleOnModal:
          description: "On the Ticket select modal, show upcoming price rule for this event"
        showCurrentPriceRuleNextToPrice:
          description: "On the Ticket select modal, show current price rule next to the price for this event"
        payeeCompany:
          description: Company that will show up on your credit card billing
        payeeContact:
          description: Contact number for the credit card billing
        seoEventType:
          description: Event type to pass to your Marketing Analytics
        performer:
          description: Group or person performing at the event (for Facebook and other analytics)
        supportContact1:
          description: Primary Contact for event support
        supportContact2:
          description: Secondary Contact for event support
        supportEmailContact:
          description: Email contact for Event Support
        processorId:
          description: A reference to the processorId that this event should use
      type: object
    exportProfileFilters:
      properties:
        utcOffset:
          description: Timezone offset from UTC in seconds
          type: integer
          format: int64
          default: 0
        eventIds:
          description: Event IDs to include in the results
          type: array
          items:
            type: integer
        includeCancelled:
          description: Include cancelled tickets in the results
          type: boolean
          default: false
        includeHeaders:
          description: Include the column headers
          type: boolean
          default: false
        useUpdatedTime:
          description: Use the last updated timestamp for filtering
          type: boolean
          default: false
      type: object
    fglTemplate:
      properties:
        name:
          type: string
        includeReceipt:
          type: boolean
      type: object
    fglCommand:
      properties:
        type:
          type: string
        data:
          type: string
        font:
          type: string
        orientation:
          type: string
        row:
          type: integer
        column:
          type: integer
        height:
          type: integer
        width:
          type: integer
      type: object
    feeSchema:
      properties:
        useBackendFees:
          description: Determines whether the frontend or backend fees are used (defaults to frontend)
          type: boolean
          example: 0 or 1
        amount:
          description: Amount to calculate fee on
          example: "121.30"
      type: object
    fee12Schema:
      properties:
        amount:
          description: Amount to calculate fee on
          example: "121.30"
        typeId:
          description: TicketType to retrieve the fee for
          type: integer
          example: "6079"
      type: object
    inviteData:
      properties:
        id:
          description: Pass an invite Id to invites by their Id
          example: "12585"
        inviteGroup:
          description: Name used to identify the group this invite is associated with
          type: string
          example: Special Race Invites
        types:
          description: Include all the invite types that this invite should respond to
          type: array
          items:
        deleted:
          description: Enable Invite
          type: boolean
          example: "0"
        eventId:
          description: Pass an eventId to select only invites that reference the eventId
          example: "101985"
        typeId:
          description: Pass a typeId to select only invites that reference the specific typeId
          example: "1095"
        email:
          description: Select invites by email address of the invitee
          type: string
          example: george@acme.com
        firstName:
          description: Select invites by the first name of the invitee
          type: string
          example: George
        lastName:
          description: Select invites by the last name of the invitee
          type: string
          example: Smith
        linkedPromoCode:
          description: Select by the PromoCode Id included in the invite
          example: "1095"
        linkedStoredValueCode:
          description: Select by the Stored Value Code Id included in the invite
          example: "1908"
        hash:
          description: Select invites by their hash value
          type: string
          example: 924ca91f4beecbc983ee10876448711a
      type: object
    phrase:
      properties:
        name:
          description: "The name of phrase. To get the list available names make a get call to \\"/api/v2/types/names\\". "
          type: string
          example: LANG_SELECTIONS
        phrase:
          description: The text for the phrase. Must be 5000 characters or less.
          type: string
        default:
          description: The default phrase.
          type: string
      type: object
    localizations:
      properties:
        id:
          description: The id of the localization.
          type: string
          example: en-US
        name:
          description: The name of the localization.
          type: string
          example: en-US
        created:
          description: The date/time the localization was created (in unix time).
          type: integer
          example: en-US
        abbreviation:
          description: The abbreviation for the localization.
          type: string
          example: en-US
        title:
          description: The title for the localization.
          type: string
          example: en-US
        iso:
          description: The iso name for the localization.
          type: string
          example: en-US
        phrases:
          description: The list of phrases if requested.
          type: array
          items:
            "$ref": #/components/schemas/phrase
        defaults:
          description: The list of defaults if requested.
          type: object
      type: object
    myName:
      properties:
        first:
          description: First name
          type: string
        last:
          description: Last name
          type: string
      type: object
    myAddress:
      properties:
        street:
          type: string
        street2:
          type: string
        city:
          type: string
        zip:
          type: string
        phone:
          type: string
