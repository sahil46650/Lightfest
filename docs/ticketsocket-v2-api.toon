  "/api/v2/my-account/orders":
    get:
      tags[1]: My Account
      summary: Returns the list of orders.
      operationId: 26815cd69d3e9bea06549f2c95d0d98b
      parameters[9]:
        - name: event
          in: query
          description: The id of the event tickets where purchased for. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: integer
        - name: ticketType
          in: query
          description: The id of the ticket types that where purchased. Supports multiple values seperated by a comma.
          required: false
          schema:
            type: integer
        - name: fromPurchaseDate
          in: query
          description: The earliest date the order was purchased.
          required: false
          schema:
            type: string
        - name: toPurchaseDate
          in: query
          description: The latest date the order was purchased.
          required: false
          schema:
            type: string
        - name: _limit
          in: query
          description: The maximum number of events to return.
          schema:
            type: number
            format: integer
        - name: _offset
          in: query
          description: The first event to return.
          schema:
            type: number
            format: integer
        - name: includeTickets
          in: query
          description: Set to true to include the ticket details.
          required: false
          schema:
            type: boolean
        - name: includeTrans
          in: query
          description: Include the order's transactions.
          required: false
          schema:
            type: boolean
        - name: includeAnswers
          in: query
          description: Include any answer's for both the orders and tickets.
          required: false
          schema:
            type: boolean
