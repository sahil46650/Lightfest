  "/api/v2/my-account":
    get:
      tags[1]: My Account
      summary: Returns the customer's information.
      operationId: d4d14cf8a936aa8f82ed8bcb30f8cf98
      responses:
        "200":
          description: The customer's information
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/object
        "401":
          description: The auth token is expired or none existings.
    put:
      tags[1]: My Account
      summary: Log in to the customer's account. Return's an auth token that can be used with remaining my account end points.
      operationId: 8cb0f4ff68ff8a1755030ae92cfbd20b
      requestBody:
        description: The customer's login information
        content:
          "application/json":
            schema:
              allOf[1]{"$ref"}:
                #/components/schemas/myLoginRequest
      responses:
        "200":
          description: The customer's auth token and basic account information
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/myLoginResponse
        "400":
          description: An error occurred.
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/error
    post:
      tags[1]: My Account
      summary: Create an account. Requeres the caller be an admin that is part of the customer group.
      operationId: c20ea0742f3eec49984ac64dba5db6ec
      requestBody:
        description: The customer's login information
        content:
          "application/json":
            schema:
              allOf[1]{"$ref"}:
                #/components/schemas/myCreateRequest
      responses:
        "204":
          description: The account was created. The user will need to verify there email address before they can sign in.
        "400":
          description: An error occurred.
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/error
  "/api/v2/my-account/event":
    get:
      tags[1]: My Account
      summary: List of the events the customer has access to.
      operationId: 792f516f0acb07570e59d0d5a3c4a613
      parameters[7]:
        - name: title
          in: query
          description: Search text in just the title - must match exactly unless you use a % to match any char
          required: false
          schema:
            type: string
        - name: search
          in: query
          description: "Search text in Title, Description, Venue, Venue Address - uses wildcard search"
          required: false
          schema:
            type: string
        - name: fromEventStart
          in: query
          description: Returns events that start after the given date. The date is a unix timestamp.
          required: false
          schema:
            type: int
            default: false
        - name: toEventStart
          in: query
          description: Returns events that start before the given date. The date is a unix timestamp.
          required: false
          schema:
            type: int
            default: false
        - name: return
          in: query
          description: "Only return events the match the value.\n * **orders** - Only return events that the user purchased a ticket for.\n * **all** - Return all matching events."
          required: false
          schema:
            type: string
            default: all
        - name: _limit
          in: query
          description: The maximum number of events to return.
          schema:
            type: int
        - name: _offset
          in: query
          description: The first event to return.
          schema:
            type: int
      responses:
        "200":
          description: The list of events.
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/eventList
        "400":
          description: An error occurred.
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/error
        "401":
          description: The auth token is expired or none existings.
  "/api/v2/my-account/ticket-type/{eventId}":
    get:
      tags[1]: My Account
