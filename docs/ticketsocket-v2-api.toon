  "/api/v2/customer":
    get:
      tags[1]: Customer
      summary: Retrieves a list of customers.
      description: Returns a list of customer user's information.
      operationId: e7d48d04feaf875fd8262713c46682bd
      parameters[6]:
        - name: _limit
          in: query
          description: Set the max number of customers to return.
          required: false
          schema:
            type: number
            format: int64
        - name: _offset
          in: query
          description: Set the number of customers to ignore before starting.
          required: false
          schema:
            type: number
            format: int64
        - name: _sort
          in: query
          description: "Sets the order the customers can be returned. Can include one or more the following columns seperated by a comma. Prefix the column with a + will sort in ascending order, - for descending order. If not provided, the customers are sorted by id. <ul><li>id</id><li>firstName</li><li>lastName</li><li>emailAddress</li><li>username</li></ul>"
          required: false
          schema:
            type: number
            format: int64
        - name: emailAddress
          in: query
          description: Search by the customer's username.
          required: false
          schema:
            type: string
        - name: firstName
          in: query
          description: Search by the customer's first name.
          required: false
          schema:
            type: string
        - name: lastName
          in: query
          description: Search by the customer's last name.
          required: false
          schema:
            type: string
      responses:
        "200":
          description: A list of matching customers.
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/userList
        "400":
          description: One or more errors occurred.
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/error
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
    post:
      tags[1]: Customer
      summary: Adds a new customer.
      description: Create a new user record for the customer.
      operationId: 47526fbfe004d13cc1c759d2d9f3dcbc
      parameters[1]:
        - name: _response
          in: query
          description: "Determines the format of repsonse. If not provided the default is id. Can be one of the following values:<ul><li>none - no body is returned.</li><li>id - The id of the customer is returend.</li><li>object - The entire object is returned.</li></ul>"
          required: false
          schema:
            type: number
            format: string
      requestBody:
        description: The new customer's information
        content:
          "application/json":
            schema:
              allOf[1]{"$ref"}:
                #/components/schemas/user
      responses:
        "200":
          description: The customer was added. The format of the response depends on the type requested in the _repsonse parameter.
          content:
            "application/json":
              schema:
                oneOf[2]{"$ref"}:
                  #/components/schemas/customerId
                  #/components/schemas/object
        "400":
          description: One or more errors occurred.
          content:
            "application/json":
              schema:
                allOf[1]{"$ref"}:
                  #/components/schemas/error
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
