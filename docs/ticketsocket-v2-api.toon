  "/api/v2/event/{id}":
    get:
      tags[1]: Events
      summary: Find Event by ID
      description: Returns a single event
      operationId: findOne
      parameters[1]:
        - name: id
          in: path
          description: Id of event to return
          required: true
          schema:
            type: integer
            format: int64
      responses:
        "200":
          "$ref": #/components/responses/SingleResponse
        "400":
          description: Invalid Event Id
  "/api/v2/event":
    get:
      tags[1]: Events
      summary: Find events that match the provided input parameters
      operationId: d72d4a5be22235ef268cf6048d03f545
      parameters[12]:
        - name: title
          in: query
          description: Search text in just the title - must match exactly unless you use a % to match any char
          required: false
          schema:
            type: string
        - name: search
          in: query
          description: "Search text in Title, Description, Venue, Venue Address - uses wildcard search"
          required: false
          schema:
            type: string
        - name: fromStart
          in: query
          description: Includes events whose start date is on or after the provided date and time. Value should be a unix timestamp in UTC.
          schema:
            type: int
        - name: toStart
          in: query
          description: Includes events whose start date is before the provided date and time. Value should be a unix timestamp in UTC.
          schema:
            type: int
        - name: fromEnd
          in: query
          description: Includes events whose ending date is on or after the provided date and time. Value should be a unix timestamp in UTC.
          schema:
            type: int
        - name: toEnd
          in: query
          description: Includes events whose ending date is before the provided date and time. Value should be a unix timestamp in UTC.
          schema:
            type: int
        - name: onsale
          in: query
          description: Filters events based on if they've been marked as onsale. This filter ignores an event's end date and cutoff. If <b>toEnd</b> isn't includes then past events will still be included.<ul><li>all - Matches all events.</li><li>onsale - Only events that are currently marked as onsale.</li><li>upcoming - Only events that have been scheduled to be onsale in the future.</li><li>onsaleupcoming - Events that are currently marked as on sale and events that have been schedule to be marked as on sale.</li><li>offsales - Event that have been marked as offsale.</li></ul>
          schema:
            type: string
        - name: published
          in: query
          description: Filters events based on if they've been published.<ul><li>all - Matches all events.</li><li>published - Only events that are currently published.</li><li>upcoming - Only events that have been scheduled to be published in the future.</li><li>publishedupcoming - Events that are currently marked as published and events that have been schedule to be marked as published.</li><li>unpublished - Event that have been marked as published.</li></ul>
          schema:
            type: string
        - name: status
          in: query
          description: "Filters events based on the select critera. If provided then onsale, published, and the date filters will be ignored.<ul><li>all - Matches all events.</li><li>availableonline - Currently available for purchase online.</li><li>upcomingonline - Only events that have been scheduled to be on sale in the future online.</li><li>availableupcomingonline -Events that currently on sale online or are upcoming.</li><li>availableboxoffice - Currently available for purchase via the box office.</li><li>upcomingboxoffice - Evants that are upcoming for purchase via the box office or are upcoming.</li><li>availableupcomingboxoffice - Currently available for purchase via the box office or are upcoming.</li><li>upcoming - All events who's start date is in the future.</li><li>ongoing - All events who's start date has past but the end date is in the future.</li><li>elapsed - All events who's end date is in the past.</li></ul>"
          schema:
            type: string
        - parameter: updatedSince
          name: updatedSince
          in: query
          description: Returns events that have been changed since the provided date. The date is a unix timestamp.
          required: false
          schema:
            type: int
        - name: _include
          in: query
          description: "Adds additional details to the results. Supports the following values:\n *  tags - Include tags.\n *  waveTimes - Include wave times\n *  sold - Include tickets sold and total available."
          required: false
          schema:
            type: string
        - name: _orderBy
          in: query
          description: "Determins the order the events are returned. Each property can be append with + or -. + indicated sort asc and - sorts deciding. If excluded the column is sorted in asceding sort. Multiple columns a seperated by a comma. You can sort by ordering, title, start, id."
          required: false
          schema:
            type: string
      responses:
        "200":
          "$ref": #/components/schemas/eventList
    post:
      tags[1]: Events
      summary: Create a new event
      description: Creates a new event from the data POSTed
      operationId: createEvent
      requestBody:
        description: Input data format
        content:
          "application/json":
            schema:
              allOf[1]{"$ref"}:
                #/components/schemas/eventData
      responses:
        "200":
          "$ref": #/components/responses/ResultResponse
