        charge:
          description: Charge for shipping.
          type: number
        twoPlusCharge:
          description: Charge for shipping two or more items.
          type: number
        chargeType:
          description: Per order or per ticket.
          type: string
        hasETickets:
          type: boolean
        requiresShippingInfo:
          description: The shipping method requires an address be provided.
          type: boolean
        allowInternational:
          description: The shipping method can ship to international addresses.
          type: boolean
        hasBadges:
          description: The shipment includes badges.
          type: boolean
      type: object
    shippingMethodResponse:
      properties:
