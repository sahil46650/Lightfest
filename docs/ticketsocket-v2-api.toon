  "/api/v2/localization":
    get:
      tags[1]: Localization
      summary: Searches the list of localization.
      description: Returns a list of localizations.
      operationId: fe42f21d7c750bc77ed10250368e06b8
      parameters[5]:
        - name: _limit
          in: query
          description: Set the max number of objects to return.
          required: false
          schema:
            type: number
            format: int64
        - name: _offset
          in: query
          description: Set the number of objects to ignore before starting.
          required: false
          schema:
            type: number
            format: int64
        - name: phrase
          in: query
          description: The phrase to include. Preforms a wild cart search.
          required: false
          schema:
            type: string
        - name: lang
          in: query
          description: Iso name of the language to return the localizations for.
          required: false
          schema:
            type: string
        - name: _include
          in: query
          description: "Adds additional details to the results. Supports the following values:\n *  phrases - Include phrases for each localization.\n *  defaults - Include the list of default phrases."
          required: false
          schema:
            type: string
      responses:
        "200":
          "$ref": #/components/responses/ListResponse
        "400":
          "$ref": #/components/responses/ErrorResponse
    post:
      tags[1]: Localization
      summary: Adds an existing location.
      operationId: 6fec072b64e391cc129e97540a0aeb65
      requestBody:
        content:
          "application/json":
            schema:
              required[1]: name
              properties:
                name:
                  description: The name of the locationizations.
                  type: boolean
                abbreviation:
                  description: Localization's abbreviation.
                  type: integer
                title:
                  description: Internal title for the localization.
                  type: string
                iso:
                  description: Iso code for the localization.
                  type: string
                phrases:
                  description: Id of the localization to copy the phrases from. If not provided the default phrases will be used.
                  type: string
              type: object
      responses:
        "200":
          description: The location was found.
          content:
            "application/json":
              schema:
                "$ref": #/components/schemas/localizations
        "400":
          "$ref": #/components/responses/ErrorResponse
        "401":
          description: The auth token is expired or none existings.
        "403":
          description: The calling user is not part of the settings group.
  "/api/v2/localization/{id}":
    get:
      tags[1]: Localization
